<div class="top-row pl-4 navbar navbar-dark">
    <a class="navbar-brand" href="">Zapper</a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="Devices">
                <span class="oi oi-audio-spectrum" aria-hidden="true"></span> Devices
            </NavLink>
            <NavLink class="nav-link" href="Scenes">
                <span class="oi oi-heart" aria-hidden="true"></span> Scenes
            </NavLink>
            <NavLink class="nav-link" href="ConfigureRemote">
                <span class="oi oi-bolt" aria-hidden="true"></span> Remotes
            </NavLink>
            <NavLink class="nav-link" href="Settings">
                <span class="oi oi-aperture" aria-hidden="true"></span> Settings
            </NavLink>
        </li>
    </ul>
</div>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

}