@using Microsoft.Extensions.Logging
@using Zapper.Core.Bluetooth
@inject ILogger<ConfigureBluetoothDevice> _logger;
@inject IBluetoothConnection _bluetoothConnection;

<h3>Configure Bluetooth</h3>
<div class="row">
    <div class="col-12">
        <ScannerButton OnScanStartAsync="StartScanning" OnScanStop="StopScanning" ScanText="Scan for Bluetooth Devices"/>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <ButtonList Items="_devices.OrderByDescending(d => d.Name?.Length)">
            <ButtonTemplate Context="device">
                @device.Name
                @device.Address
                @device.Alias
                @device.Icon
                @device.Modalias
                @device.AddressType
            </ButtonTemplate>
        </ButtonList>
    </div>
</div>