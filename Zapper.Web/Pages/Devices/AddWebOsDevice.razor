@page "/AddWebOsDevice"
@using Zapper.Core.WebOs
@using Zapper.Web.Shared.Devices

<h2>Add WebOS TV</h2>
@if (_scanning)
{
    <ScanningCard Text="Scanning for WebOS Device..."/>
}
@if(!_scanning && _scanned && !_tvs.Any())
{
    <NoWebOsDevicesFound ScanCallback="Scan"/>
}
@if(!_scanning && _scanned && _tvs.Any())
{
    <WebOsDevices @tvs="_tvs" @AddDevice="AddDevice"/>
}

@code {

    private bool _scanning;
    private bool _scanned;
    List<LgTvScanner.TvData> _tvs = new();

    protected override async Task OnInitializedAsync()
    {
        await Scan();
    }

    private async Task Scan()
    {
        await Task.Run(async () =>
        {
            if (_scanning)
                return;

            try
            {
                _scanning = true;
                await InvokeAsync(StateHasChanged);

                var scanner = new LgTvScanner();

                _tvs = scanner.LgTvScan();
            }
            catch
            {
    // ignored
            }
            finally
            {
                _scanning = false;
                _scanned = true;

                await InvokeAsync(StateHasChanged);
            }
        });
    }
}