@page "/ManageDevice/{DeviceId:guid}"
@using Zapper.Core.Devices
@using Zapper.Core.Devices.Abstract
@using Microsoft.Extensions.Logging
@inject IDeviceManager _deviceManager
@inject ILogger<ManageDevice> _logger
@inject NavigationManager _navigationManager

<h3>Device Name</h3>
<ul>
    <li>
        <strong>IP Address</strong> @_device.IpAddress
    </li>
    <li>
        <strong>Mac Address</strong> @_device.MacAddress
    </li>
    <li>
        <strong>Device Type</strong> @_device.SupportDeviceType
    </li>
    <li>
        <strong>Id</strong> @_device.Id
    </li>
    <li><strong>Currently On?</strong> ???</li>
    <li><strong>Model Number</strong> Yes it has one</li>
    <li><strong>Apps Installed</strong> Yes there are apps installed</li>
    <li><strong>Current Volume</strong> ???</li>
</ul>
<h4>Actions</h4>
<ul>
    <li>
        <button class="btn btn-primary">
            Edit
        </button>
    </li>
    <li>Manually Trigger Device Actions</li>
    <li>Test Device Connection</li>
    <li>
        <button class="btn btn-danger" @onclick="DisplayConfirmationDialog">
            Remove Device
        </button>
    </li>
</ul>
<ConfirmationModal @ref="_confirmationModal" OnConfirmYes="RemoveDevice"/>

@code {

    [Parameter]
    public Guid DeviceId { get; set; }

    private Device _device;
    private ConfirmationModal _confirmationModal;

    protected override void OnInitialized()
    {
        var device = _deviceManager.Get(DeviceId);
        _device = device;
    }

    private void DisplayConfirmationDialog()
    {
        _confirmationModal.Open();
    }

    private void RemoveDevice()
    {
        try
        {
            _logger.LogInformation($"Attempting to remove device: {_device.Id}");

            _deviceManager.Delete(_device.Id);
            _navigationManager.NavigateTo("/Devices");

            _logger.LogInformation("Successfully removed device");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error occurred while trying to remove device");
        }
    }

}